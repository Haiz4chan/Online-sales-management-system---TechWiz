@model WebBanHangOnline.Models.RegisterViewModel
@{
    ViewBag.Title = "Đăng ký";
}
<link rel="stylesheet" type="text/css" href="~/Content/assets/styles/main_styles.css">

<div class="container" style="margin-top:160px; margin-bottom: 50px;">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2 class="text-uppercase">@ViewBag.Title</h2>

            @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
            {
                @Html.AntiForgeryToken()
                <h4>Tạo tài khoản mới để trải nghiệm công nghệ tại TechWiz</h4>
                <hr />
                @Html.ValidationSummary("", new { @class = "text-danger" })

                <div class="form-group row">
                    <label class="col-md-3 col-form-label">Email đăng nhập</label>
                    <div class="col-md-9">
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Vd: techwiz@gmail.com" })
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-md-3 col-form-label">Mật khẩu</label>
                    <div class="col-md-9">
                        @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Nhập mật khẩu..." })
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-md-3 col-form-label">Xác nhận mật khẩu</label>
                    <div class="col-md-9">
                        @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "Nhập lại mật khẩu..." })
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-md-offset-3 col-md-9">
                        <input type="submit" class="btn btn-danger px-4" value="Đăng ký ngay" />
                    </div>
                </div>

                <p class="mt-3">
                    Bạn đã có tài khoản? <a href="/account/login" class="text-danger">Đăng nhập tại đây</a>
                </p>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}